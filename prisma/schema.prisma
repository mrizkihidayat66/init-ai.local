// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  status      String        @default("CLARIFYING") // CLARIFYING | REQUIREMENTS_LOCKED | PLAN_GENERATED | IN_PROGRESS | COMPLETED
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  conversations Conversation[]
  plan          Plan?
  contextLogs   ContextLog[]
  commits       Commit[]
}

model Conversation {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role      String   // USER | ASSISTANT | SYSTEM
  content   String
  metadata  String?  // JSON string for structured data (options, etc.)
  createdAt DateTime @default(now())
}

model Plan {
  id        String   @id @default(cuid())
  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version   Int      @default(1)

  prd           String?  // Product Requirements Document
  architecture  String?  // System design markdown
  taskList      String?  // task.md content
  apiSpec       String?  // API specification
  dbSchema      String?  // Database schema doc
  rules         String?  // Agent ruleset / .cursorrules
  workflow      String?  // Development workflow steps
  diagrams      String?  // Mermaid diagrams
  promptContext String?  // Bootstrap context for AI tools
  effortEstimate String?  // Effort estimation (story points, timeline, team)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  snapshots PlanSnapshot[]
}

model PlanSnapshot {
  id        String   @id @default(cuid())
  planId    String
  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  version   Int
  content   String   // JSON blob of all section content
  createdAt DateTime @default(now())
}

model ContextLog {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  source    String   // e.g. "antigravity", "copilot", "manual"
  type      String   // e.g. "progress", "error", "note", "milestone"
  content   String
  metadata  String?  // JSON string
  createdAt DateTime @default(now())
}

model Commit {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version   String   // semver or sequential "v1", "v2"
  message   String
  diff      String?  // optional unified diff
  snapshot  String?  // optional JSON snapshot of project state
  author    String   // "user", "antigravity", "copilot", etc.
  parentId  String?  // reference to previous commit for chain
  createdAt DateTime @default(now())
}

model Settings {
  id           String   @id @default("default")
  provider     String   @default("openai")  // openai | anthropic | google | ollama
  model        String   @default("auto")
  customModels String?  // comma-separated custom model list
  apiKey       String?
  baseUrl      String?  // for Ollama or custom endpoints
  temperature  Float    @default(0.7)
  updatedAt    DateTime @updatedAt
}
